# KAIF production-like example
# This file is a template only. Do not commit real secrets.
# The compose overlay in this repo is a production rehearsal, not a true production deployment.

# Server
NODE_ENV=production
KAIF_PORT=8080
KAIF_HOST_PORT=18080
KAIF_HOST=0.0.0.0
KAIF_ISSUER=https://kaif.kindredsystems.ai
KAIF_ALLOWED_AUDIENCES=https://kaif.kindredsystems.ai
KAIF_LOG_LEVEL=info
KAIF_DEV_MODE=false
KAIF_TENANT_ADDRESS=tenant-prod

# Redis
# Local production rehearsal uses the internal compose Redis and requires the explicit controlled-test override.
# Real production should use a dedicated Azure Managed Redis rediss:// endpoint and set KAIF_ALLOW_INSECURE_REDIS=false.
KAIF_REDIS_URL=redis://redis:6379
KAIF_ALLOW_INSECURE_REDIS=true

# SPIRE
KAIF_SPIRE_BUNDLE_ENDPOINT=https://spire-server:8081/
KAIF_SPIRE_BUNDLE_CA_PATH=/run/secrets/spire-bundle-ca.pem
# Alternative to file-mounted bundle CA:
# KAIF_SPIRE_BUNDLE_CA_PEM="-----BEGIN CERTIFICATE-----...\n-----END CERTIFICATE-----"
KAIF_SPIRE_TRUST_DOMAIN=kindred.systems

# Human IdP
KAIF_IDP_JWKS_URL=https://login.microsoftonline.com/<tenant>/discovery/v2.0/keys
KAIF_IDP_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0

# Keys
KAIF_PRIVATE_KEY_PATH=/run/secrets/kaif-signing-key.pem
# Alternative secret-store injection path:
# KAIF_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----..."
# KAIF_RETAINED_KEY_PEMS="-----BEGIN PUBLIC KEY-----...\n---\n-----BEGIN PUBLIC KEY-----..."
# Alternative Azure Key Vault secret path:
# KAIF_AZURE_KEY_VAULT_URL=https://kaif-kv.vault.azure.net
# KAIF_AZURE_PRIVATE_KEY_SECRET_NAME=kaif-signing-key
# KAIF_AZURE_PRIVATE_KEY_SECRET_VERSION=
# KAIF_AZURE_RETAINED_KEY_SECRETS=kaif-signing-key-v1-public,kaif-signing-key-v2-public@<version>
# Local container rehearsal with a service principal also needs:
# AZURE_TENANT_ID=<tenant-id>
# AZURE_CLIENT_ID=<app-client-id>
# AZURE_CLIENT_SECRET=<client-secret>

# Config
KAIF_AGENTS_CONFIG_PATH=/app/config/agents.yaml
KAIF_STRICT_REVOCATION=false

# Adaptive governance integration
KAIF_GOVERNANCE_AUDIT_APPEND_URL=https://adaptive.example.internal/v1/audit/append
KAIF_GOVERNANCE_WORKSPACE_ID=ws-kaif
KAIF_GOVERNANCE_PROJECT_ID=kaif
KAIF_GOVERNANCE_UI_INSTANCE_ID=ui-kaif
KAIF_CLASS_C_DEGRADED_OPEN=false
