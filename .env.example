# Server
KAIF_PORT=8080
KAIF_HOST_PORT=18080
KAIF_HOST=0.0.0.0
KAIF_ISSUER=http://localhost:18080
KAIF_ALLOWED_AUDIENCES=http://localhost:18080
KAIF_LOG_LEVEL=info
KAIF_DEV_MODE=true
KAIF_TENANT_ADDRESS=tenant-example

# Redis
KAIF_REDIS_URL=redis://localhost:6380
KAIF_REDIS_HOST_PORT=6380
# Production/staging should use a dedicated KAIF Redis endpoint with TLS:
# KAIF_REDIS_URL=rediss://kaif-redis.example.internal:6380
# KAIF_ALLOW_INSECURE_REDIS=true is only for controlled production-like tests.
KAIF_ALLOW_INSECURE_REDIS=false

# SPIRE
KAIF_SPIRE_BUNDLE_ENDPOINT=https://localhost:8081/
# Local dev only: SPIRE serves https_spiffe with a dev trust root.
# Production must validate TLS normally and leave this false/unset.
KAIF_SPIRE_BUNDLE_TLS_INSECURE=true
# Production/staging: set this to the trusted SPIRE bundle endpoint CA file.
# KAIF_SPIRE_BUNDLE_CA_PATH=/run/secrets/spire-bundle-ca.pem
KAIF_SPIRE_TRUST_DOMAIN=kindred.systems

# Human IdP (Azure Entra / any OIDC)
KAIF_IDP_JWKS_URL=https://login.microsoftonline.com/{tenant}/discovery/v2.0/keys
KAIF_IDP_ISSUER=https://login.microsoftonline.com/{tenant}/v2.0

# Keys
KAIF_PRIVATE_KEY_PATH=

# Config
KAIF_AGENTS_CONFIG_PATH=./packages/server/config/agents.yaml
KAIF_STRICT_REVOCATION=false  # true = every token use hits introspect

# Adaptive governance integration
KAIF_GOVERNANCE_AUDIT_APPEND_URL=
KAIF_GOVERNANCE_WORKSPACE_ID=ws-kaif
KAIF_GOVERNANCE_PROJECT_ID=kaif
KAIF_GOVERNANCE_UI_INSTANCE_ID=ui-kaif
KAIF_CLASS_C_DEGRADED_OPEN=false

# DNS boundary handoff (optional)
# When enabled, KAIF writes the Foundry receipt to DNS context and resumes the paused run.
KAIF_DNS_DELIVERY_ENABLED=false
KAIF_DNS_BASE_URL=http://127.0.0.1:19082
KAIF_DNS_AUTH_MODE=both
KAIF_DNS_AUTH_TOKEN=
KAIF_DNS_WRITE_TIMEOUT_MS=15000
KAIF_DNS_RESUME_TIMEOUT_MS=10000

# Redis channel offload worker (warm storage)
# Run with: pnpm --filter @kaif/server offload:redis-cosmos
KAIF_COSMOS_ENDPOINT=
KAIF_COSMOS_KEY=
KAIF_COSMOS_DATABASE=kaif-warm
KAIF_COSMOS_CONTAINER=channel-events
KAIF_COSMOS_CONTAINER_PARTITION_KEY=/channel
KAIF_COSMOS_DEFAULT_TTL_SECONDS=2592000
KAIF_REDIS_CHANNELS=kaif:audit,kaif:revocation,kaif:authorization-tier
KAIF_OFFLOAD_INCLUDE_RAW=false
