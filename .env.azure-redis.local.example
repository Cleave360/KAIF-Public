# Local Azure Redis rehearsal for KAIF
# Copy to .env.azure-redis.local (gitignored) and fill in real secrets.

# Server
KAIF_PORT=8080
KAIF_HOST_PORT=18080
KAIF_HOST=0.0.0.0
KAIF_ISSUER=http://localhost:18080
KAIF_ALLOWED_AUDIENCES=http://localhost:18080
KAIF_LOG_LEVEL=info
KAIF_DEV_MODE=true
KAIF_TENANT_ADDRESS=tenant-example

# Redis
KAIF_REDIS_URL=rediss://default:{redis-access-key}@{cache-name}.{region}.redis.azure.net:10000
KAIF_ALLOW_INSECURE_REDIS=false

# SPIRE
KAIF_SPIRE_BUNDLE_ENDPOINT=https://localhost:8081/
KAIF_SPIRE_BUNDLE_TLS_INSECURE=true
KAIF_SPIRE_TRUST_DOMAIN=kindred.systems

# Human IdP (not required when KAIF_DEV_MODE=true)
KAIF_IDP_JWKS_URL=https://login.microsoftonline.com/{tenant}/discovery/v2.0/keys
KAIF_IDP_ISSUER=https://login.microsoftonline.com/{tenant}/v2.0

# Keys
KAIF_PRIVATE_KEY_PATH=

# Config
KAIF_AGENTS_CONFIG_PATH=./packages/server/config/agents.yaml
KAIF_STRICT_REVOCATION=false

# Adaptive governance integration
KAIF_GOVERNANCE_AUDIT_APPEND_URL=
KAIF_GOVERNANCE_WORKSPACE_ID=ws-kaif
KAIF_GOVERNANCE_PROJECT_ID=kaif
KAIF_GOVERNANCE_UI_INSTANCE_ID=ui-kaif
KAIF_CLASS_C_DEGRADED_OPEN=false
