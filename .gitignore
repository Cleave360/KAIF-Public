# KAIF .gitignore
# Comprehensive ignore rules for Node.js/TypeScript project with SPIRE, Redis, and Docker

# ─────────────────────────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────────────────────────
node_modules/
*.nest/
.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─────────────────────────────────────────────────────────────────
# Build & Distribution
# ─────────────────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo
.tsc-output/
out/

# ─────────────────────────────────────────────────────────────────
# Environment & Configuration
# ─────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ─────────────────────────────────────────────────────────────────
# IDE & Editor
# ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
*.sublime-workspace
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-project

# ─────────────────────────────────────────────────────────────────
# OSX
# ─────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ─────────────────────────────────────────────────────────────────
# Windows
# ─────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ─────────────────────────────────────────────────────────────────
# Testing
# ─────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
.mocha-snapshots/
.vitest/

# ─────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────
logs
*.log
*.log.*
pino-pretty.log

# ─────────────────────────────────────────────────────────────────
# Temporary Files
# ─────────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.backup
.cache/

# ─────────────────────────────────────────────────────────────────
# Secrets & Keys (CRITICAL)
# ─────────────────────────────────────────────────────────────────
keys/
*.pem
*.key
*.p8
*.p12
*.pfx
*.jks
.vault-token
.gpg-cache/
secrets/

# ─────────────────────────────────────────────────────────────────
# Docker & Infrastructure
# ─────────────────────────────────────────────────────────────────
docker-compose.override.yml
.dockerignore
docker-sync.yml

# ─────────────────────────────────────────────────────────────────
# Kubernetes
# ─────────────────────────────────────────────────────────────────
k8s/
*.yaml.bak
kubeconfig.yaml

# ─────────────────────────────────────────────────────────────────
# SPIRE / Workload Identity
# ─────────────────────────────────────────────────────────────────
spire/data/
/run/
*.spire-token

# ─────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────
redis-dump.rdb
redis-data/
*.rdb
appendonly.aof

# ─────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-journal

# ─────────────────────────────────────────────────────────────────
# Node Package Manager
# ─────────────────────────────────────────────────────────────────
.npmrc-local
npm-shrinkwrap.json.bak
pnpm-lock.yaml.bak

# ─────────────────────────────────────────────────────────────────
# OS-specific
# ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─────────────────────────────────────────────────────────────────
# Git
# ─────────────────────────────────────────────────────────────────
.git/
.gitkeep
.gitmodules

# ─────────────────────────────────────────────────────────────────
# Certificates & HTTPS (Development Only)
# ─────────────────────────────────────────────────────────────────
*.crt
*.csr
!.env.example

# ─────────────────────────────────────────────────────────────────
# Conformance & Evidence Reports (generated by scripts/day7b_*)
# ─────────────────────────────────────────────────────────────────
reports/

# ─────────────────────────────────────────────────────────────────
# CI/CD & CI Artifacts
# ─────────────────────────────────────────────────────────────────
.github/workflows/.tmp/
.gitlab-ci.yml.bak
.circleci/config.yml.bak
.travis.yml.bak

# ─────────────────────────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────────────────────────
.venv/
venv/
env/
Pipfile.lock
yarn.lock.bak
.pnm-lock.yaml
